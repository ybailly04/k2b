{
    "name": "bim/timber2",
    "description": "ACF PRO in a WordPress site",
    "repositories": [
        {
            "type":"composer",
            "url":"https://connect.advancedcustomfields.com"
        },
        {
            "type":"composer",
            "url":"https://wpackagist.org",
            "only": [
                "wpackagist-plugin/*"
            ]
        }
    ],
    "require": {
        "timber/timber": "^2.0",
        "wpengine/advanced-custom-fields-pro": "^6.0",
        "wpackagist-plugin/regenerate-thumbnails":"^3.1.5",
        "wpackagist-plugin/seo-by-rank-math":"^1.0",
        "vlucas/phpdotenv": "^5.5",
        "hellonico/timber-dump-extension": "^1.0",
        "mindkomm/timmy": "^2.2"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
