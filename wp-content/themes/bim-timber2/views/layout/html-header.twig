<!doctype html>
<html class="no-js no-svg {% if landing %}bim-landing-wrapper{% endif %}" {{ site.language_attributes }}>
<head>
    <meta charset="{{ site.charset }}" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="pingback" href="{{ site.pingback_url }}" />
    <link rel="profile" href="http://gmpg.org/xfn/11">
    <link rel="icon" href="{{ site.theme.link }}/favicon.ico" sizes="any">
    {{function('wp_head')}}

    {% set manifest = {
        'js': manifest['app.js'].file,
        'css': manifest['style.css'].file
    } %}

    <script src="{{ manifest.js }}"></script>
    <link rel="stylesheet" href="{{ manifest.css }}">
