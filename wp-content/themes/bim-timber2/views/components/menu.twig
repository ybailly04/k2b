<ul class="menu">
	{% for item in items %}
		{% set current = item.current or 'current-page-ancestor' in item.class %}
		<li class="{{ item.classes|join(' ') }}">
			<a href="{{ item.link }}" class="menu-item-link {% if current %}menu-item-link--active{% endif %}">{{ item.title }}</a>

			{% if item.children %}
				<ul class="submenu">
					{% for subitem in item.children %}
						{% set subcurrent = subitem.current or 'current-page-ancestor' in subitem.class %}
						<li class="submenu-item">
							<a href="{{ subitem.link }}" class="submenu-item-link {% if subcurrent %}submenu-item-link--active{% endif %}">{{ subitem.title }}</a>
						</li>
					{% endfor %}
				</ul>
			{% endif %}
		</li>
	{% endfor %}
</ul>
